{
    "name": "@front-engine/utils-react",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./components": {
            "types": "./dist/components/index.d.ts",
            "import": "./dist/components/index.js"
        },
        "./permissions": {
            "types": "./dist/permissions/index.d.ts",
            "import": "./dist/permissions/index.js"
        },
        "./hooks": {
            "types": "./dist/hooks/index.d.ts",
            "import": "./dist/hooks/index.js"
        },
        "./contexts": {
            "types": "./dist/contexts/index.d.ts",
            "import": "./dist/contexts/index.js"
        },
        "./routes": {
            "types": "./dist/routes/index.d.ts",
            "import": "./dist/routes/index.js"
        },
        "./styles.css": {
            "import": "./src/styles.css"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "tsc -b --watch",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@front-engine/tailwind-config": "workspace:*",
        "@front-engine/utils-ts": "workspace:*",
        "@front-engine/api": "workspace:*",
        "@front-engine/ui": "workspace:*",
        "primereact": "^10.9.7",
        "primeicons": "^7.0.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router-dom": "^7.9.6"
    },
    "devDependencies": {
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^4.3.4",
        "typescript": "^5.6.3",
        "vite": "^6.0.1",
        "vite-plugin-dts": "^4.3.0"
    },
    "peerDependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    }
}
